# Copy or generate — from backend-script/:
#   npm run env:print
#   npm run env:write
#
# Or: cp .env.example .env  (then edit)

# Anvil RPC
RPC_URL=http://127.0.0.1:8545

# Contract addresses (from core/operator deployments)
NOFEESWAP=0x
NOFEESWAP_DELEGATEE=0x
OPERATOR=0x

# Token addresses (sorted: token0 < token1)
TOKEN0=0x
TOKEN1=0x

# Attacker private key — not the same account as the UI user (e.g. Anvil #1)
ATTACKER_PRIVATE_KEY=0x

# Minimum profitability threshold in wei before executing sandwich
MIN_PROFIT_WEI=0

# Polling interval (ms) for pending txpool scans
POLL_INTERVAL_MS=200

{
  "name": "sandwich-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node --experimental-specifier-resolution=node dist/index.js",
    "dev": "tsx src/index.ts",
    "setup": "tsx src/setup.ts",
    "env:print": "node scripts/print-env-from-deployments.mjs",
    "env:write": "node scripts/print-env-from-deployments.mjs --write"
  },
  "dependencies": {
    "viem": "^2.27.0",
    "chalk": "^5.4.1",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0"
  }
}

# --- Folders you keep out of this repo (upstream clones) ---


# --- Node (any package) ---
node_modules/
**/node_modules/

# --- Next.js / frontend ---
.next/
out/
.turbo/

# --- TypeScript / tooling ---
dist/
*.tsbuildinfo

# --- Python ---
**/__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.eggs/
venv/
.venv/
env/

# --- Solidity / Brownie ---
**/artifacts/
**/cache/
**/.brownie/
**/reports/
# Explicit (some Git versions do not ignore nested build/ reliably)
core/build/
operator/build/

# --- Env & secrets ---
.env
.env.local
.env.*.local
!.env.example

# --- Logs & debug ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- OS & editors ---
.DS_Store
Thumbs.db
.idea/
*.swp
*.swo

# --- Misc ---
coverage/
.vercel
